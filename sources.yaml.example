sources:
  - name: "Internet Archive"
    type: s3
    endpoint: "https://s3.us.archive.org/your-bucket"
    access_key: "your-access-key"
    secret_key: "your-secret-key"
    options:
      resolve_redirect: true
    catalogs:
      - path: "fhw-nes-roms"
        platform: "NES"
      - path: "fhw-ps1-roms"
        platform: "PS1"
